    ((= idx 16) 'complication-disassociate)
    ((= idx 17) 'complication-bus-driver)
    ((= idx 18) 'rule-buzzer-pressure)
    ((= idx 19) 'complication-wings-tied)
    ((= idx 20) 'rule-survivor)
    ((= idx 21) 'complication-fuel-shortage)
    ((= idx 22) 'complication-drought)
    ((= idx 23) 'rule-management)
    ((= idx 24) 'complication-jak-rabbit)
    ((= idx 25) 'complication-hidden-treasure)
    ((= idx 26) 'rule-vendetta)
