    ((= idx 8) 'rule-money-pressure)
    ((= idx 9) 'rule-fuel-pressure)
    ((= idx 10) 'complication-eco-allergy)
    ((= idx 11) 'complication-sizeable)
    ((= idx 12) 'complication-ohko)
    ((= idx 13) 'complication-glare)
    ((= idx 14) 'complication-heating-balloons)
