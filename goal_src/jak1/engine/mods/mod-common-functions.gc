    ((eq? id 'rule-button-pusher) "PUSH A BUTTON.")
    ((eq? id 'complication-invisible-man) "JAK IS INVISIBLE.")
    ((eq? id 'rule-cooked) "BURN JAK.")
    ((eq? id 'complication-joyride) "HEY! THERE\c12S THE FLUT-FLUT!")
    ((eq? id 'rule-sagging-sails) "MISS 3 5-POUND FISH.")
    (else "NO DESCRIPTION AVAILABLE.")))

