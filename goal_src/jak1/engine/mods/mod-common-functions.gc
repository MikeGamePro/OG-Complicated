(defun mod-rule-goal-kind ((id symbol))
  (cond
    ((eq? id 'rule-lurker-pressure) 'counter)
    ((eq? id 'rule-hitlist) 'counter)
    ((eq? id 'rule-crate-break) 'counter)
    ((eq? id 'rule-money-pressure) 'counter)
    ((eq? id 'rule-fuel-pressure) 'event-once)
    ((eq? id 'rule-sniper) 'event-once)
    ((eq? id 'rule-buzzer-pressure) 'counter)
    ((eq? id 'rule-die) 'event-once)
    ((eq? id 'rule-one-frame) 'event-once)
    ((eq? id 'rule-vendetta) 'event-once)
    ((eq? id 'rule-for-billy) 'event-once)
    ((eq? id 'rule-speed) 'event-once)
    ((eq? id 'rule-green-pilled) 'counter)
    ((eq? id 'rule-button-pusher) 'event-once)
    ((eq? id 'rule-cooked) 'event-once)
    ((eq? id 'rule-sagging-sails) 'counter)
    (else 'none)))

(defun mod-rule-counter-goal ((id symbol))
  (cond
    ((eq? (mod-rule-goal-kind id) 'event-once) 1)
