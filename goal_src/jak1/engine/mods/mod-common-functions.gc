;; tracks which trivia questions have already been rolled this run, sized to match *trivia-questions*
(define *trivia-questions-used* (new 'global 'boxed-array symbol 30))

(defun mod-rule-clear-trivia-used ()
  (let ((i 0))
    (while (< i 30)
      (set! (-> *trivia-questions-used* i) #f)
      (+! i 1)))
  (none))

(defun mod-rule-trivia-pick-question ()
  (let ((count (length *trivia-questions*))
        (all-used? #t)
        (i 0))
    (while (< i count)
      (when (not (-> *trivia-questions-used* i))
        (set! all-used? #f))
      (+! i 1))
    (when all-used?
      (mod-rule-clear-trivia-used))
    (let ((idx (knuth-rand-int-range 0 count)))
      (while (-> *trivia-questions-used* idx)
        (set! idx (knuth-rand-int-range 0 count)))
      (set! (-> *trivia-questions-used* idx) #t)
      idx)))

(defun hide-all-water ((hide? symbol))
  (iterate-process-tree *active-pool*
    (lambda ((p process))
      (when (type-type? (-> p type) water-anim)
        (if hide?
          (logior! (-> (the-as water-anim p) draw status) (draw-status hidden))
          (logclear! (-> (the-as water-anim p) draw status) (draw-status hidden)))))
    *null-kernel-context*))

(defun refresh-money-actors ()
  (iterate-process-tree *active-pool*
    (lambda ((p process))
      (when (type-type? (-> p type) money)
        (logclear! (-> (the-as money p) draw status) (draw-status hidden))
        (restore-collide-with-as (-> (the-as money p) root))))
    *null-kernel-context*))

